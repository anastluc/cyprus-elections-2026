# Copy to .env and fill in. Never commit .env.

# OpenRouter (https://openrouter.ai) — used for structured extraction,
# entity matching across sources, and LLM-based validation/confidence.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# Optional: a search-capable model for the web_search enrich step.
OPENROUTER_SEARCH_MODEL=perplexity/sonar

# Airtable mirror (optional — pipeline runs fine without these; CSV export always works).
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_CANDIDATES=Candidates
AIRTABLE_TABLE_FIELDS=CandidateFields
